# Core Infrastructure
DIGIQUARIUM_HOME=/home/ijneb/digiquarium
OLLAMA_HOST=192.168.50.94
OLLAMA_PORT=11434
OLLAMA_LOCAL_PORT=11435

# Anthropic API (required for chat-ui)
ANTHROPIC_API_KEY=your-api-key-here

# Tank Configuration (set by docker-compose)
TANK_NAME=specimen
GENDER=a being
LANGUAGE=english
TANK_ID=tank-01
TANK_TYPE=standard

# Ollama Configuration (for tanks)
OLLAMA_URL=http://digiquarium-ollama:11434
OLLAMA_MODEL=llama3.2:latest

# Storage & Logging
LOG_DIR=/logs

# Kiwix URLs (for knowledge access)
KIWIX_URL=http://digiquarium-kiwix-simple:8080
WIKI_BASE=/wikipedia_en_simple_all_nopic_2026-02

# Agent Configuration
AGENT_TYPE=standard
HAS_IMAGES=false

# Visitor Tank Access (used by THE BOUNCER)
VISITOR_ACCESS_PASSWORD=change-me-to-a-secure-password
